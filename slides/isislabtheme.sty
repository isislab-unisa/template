    \fill[ISISBg] (current page.south west) rectangle (current page.north east);
    \fill[ISISBlue] (current page.north west) rectangle ([yshift=-1.6mm]current page.north east);
    \fill[ISISGold] ([yshift=1.2mm]current page.south west) rectangle (current page.south east);
    \node[anchor=north west] at ([xshift=3mm,yshift=-3mm]current page.north west) {\includegraphics[width=18mm]{logo_standard_shadow.png}};
    \node[anchor=north east] at ([xshift=-5mm,yshift=-4mm]current page.north east) {\includegraphics[width=16mm]{dipartimento_informatica_logo.png}};
    \node[anchor=north east,opacity=.10] at ([xshift=0mm,yshift=-25mm]current page.north east) {\includegraphics[width=.5\paperwidth]{topo.png}};
  \node at ([xshift=-105mm,yshift=-70mm]current page.north east) {%
     \ISISBadge[ISISLogoBlue]{ISISLab}\hspace{1mm}%
