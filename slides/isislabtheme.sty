% ISISLab Beamer Theme
% Clean almost-white scientific template with ISISLab blue accents.
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{isislabtheme}[2026/07/16 ISISLab Beamer theme]

% Language option for fixed template labels.
% Usage: \usepackage[italian]{isislabtheme} (aliases: italiano, ita)
\newif\ifISISItalian
\ISISItalianfalse
\DeclareOption{english}{\ISISItalianfalse}
\DeclareOption{italian}{\ISISItaliantrue}
\DeclareOption{italiano}{\ISISItaliantrue}
\DeclareOption{ita}{\ISISItaliantrue}
\ProcessOptions\relax

\newcommand{\ISISAgendaName}{\ifISISItalian Indice\else Agenda\fi}
\newcommand{\ISISSectionName}{\ifISISItalian SEZIONE\else SECTION\fi}
\newcommand{\ISISDepartmentName}{\ifISISItalian Dipartimento di Informatica\else Department of Computer Science\fi}
\newcommand{\ISISUniversityName}{\ifISISItalian Università degli Studi di Salerno\else Università degli Studi di Salerno (Italy) \fi}

\RequirePackage{tikz}
\RequirePackage{graphicx}
\RequirePackage{xcolor}
\RequirePackage{calc}
\RequirePackage{xparse}
\RequirePackage{fontawesome5}
\usetikzlibrary{positioning,arrows.meta,calc,shadows.blur,fit,backgrounds}

\graphicspath{{assets/}}

