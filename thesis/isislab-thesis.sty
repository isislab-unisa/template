\newenvironment{frontmatterbox}{%
  \def\FrameCommand##1{\hspace{0pt}\textcolor{ThesisAccent}{\vrule width 3pt}\hspace{5mm}##1}%
  \MakeFramed{\advance\hsize-8mm\FrameRestore}%
}{\endMakeFramed}

\newenvironment{keypoint}[1][\LangText{Key point}{Punto chiave}]{%
  \par\medskip
  \def\FrameCommand##1{\hspace{0pt}\textcolor{ISISLightBlue}{\vrule width 3pt}\hspace{5mm}##1}%
  \MakeFramed{\advance\hsize-8mm\FrameRestore}%
  \noindent{\sffamily\bfseries\color{ISISDeepBlue}#1}\par\smallskip
}{\endMakeFramed\medskip}

