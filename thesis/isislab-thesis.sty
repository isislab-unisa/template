% -----------------------------------------------------------------------------
% One-command project selection
% -----------------------------------------------------------------------------
\def\ISIS@degree{master}
\def\ISIS@language{italian}

\newcommand{\thesisdegree}[1]{%
  \edef\ISIS@choice{#1}% expand configuration variables first
  \ifdefstring{\ISIS@choice}{bachelor}{\def\ISIS@degree{bachelor}}{%
    \ifdefstring{\ISIS@choice}{master}{\def\ISIS@degree{master}}{%
      \PackageError{isislab-thesis}{Unknown thesis degree '\ISIS@choice'}{Use \string\thesisdegree{bachelor} or \string\thesisdegree{master}.}%
    }%
  }%
}

\newcommand{\thesislanguage}[1]{%
  \edef\ISIS@choice{#1}% expand configuration variables first
  \ifdefstring{\ISIS@choice}{english}{\def\ISIS@language{english}}{%
    \ifdefstring{\ISIS@choice}{en}{\def\ISIS@language{english}}{%
      \ifdefstring{\ISIS@choice}{italian}{\def\ISIS@language{italian}}{%
        \ifdefstring{\ISIS@choice}{it}{\def\ISIS@language{italian}}{%
          \PackageError{isislab-thesis}{Unknown thesis language '\ISIS@choice'}{Use \string\thesislanguage{english} or \string\thesislanguage{italian}.}%
        }%
      }%
    }%
  }%
}

\newcommand{\IfBachelorTF}[2]{\ifdefstring{\ISIS@degree}{bachelor}{#1}{#2}}
\newcommand{\IfMasterTF}[2]{\ifdefstring{\ISIS@degree}{master}{#1}{#2}}
\newcommand{\IfItalianTF}[2]{\ifdefstring{\ISIS@language}{italian}{#1}{#2}}
\newcommand{\IfEnglishTF}[2]{\ifdefstring{\ISIS@language}{english}{#1}{#2}}
\newcommand{\LangText}[2]{\IfItalianTF{#2}{#1}}

\AtBeginDocument{%
  \selectlanguage{\ISIS@language}%
  \IfItalianTF{\renewcommand{\bibname}{Bibliografia}}{\renewcommand{\bibname}{References}}%
  \hypersetup{pdftitle={\@thesistitle},pdfauthor={\@thesisauthor}}%
}

