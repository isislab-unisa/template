% Running page furniture
\clearpairofpagestyles
\ihead{\sffamily\small\textcolor{ISISMuted}{\headmark}}
\ohead{\sffamily\small\textcolor{ISISBlue}{\@thesislevel}}
\cfoot{\begin{tikzpicture}[baseline=-0.45ex]
  \fill[ISISLine] (-2.1,0) rectangle (2.1,0.7pt);
  \fill[ThesisAccent] (-2.1,0) rectangle (-0.6,0.7pt);
\end{tikzpicture}\quad\sffamily\bfseries\textcolor{ISISDeepBlue}{\thepage}}
\pagestyle{scrheadings}
\renewcommand*{\chapterpagestyle}{scrheadings}
\automark[section]{chapter}

% Chapter and section typography
\titleformat{\chapter}[display]
  {\normalfont\sffamily\bfseries\color{ISISDeepBlue}}
  {\begin{tikzpicture}[baseline=(n.base)]
    \node[fill=ThesisAccent,rounded corners=3pt,minimum width=1.35cm,minimum height=1.05cm,text=white,font=\sffamily\bfseries\Large] (n) {\thechapter};
   \end{tikzpicture}}
  {0.7em}
  {\Huge}
  [\vspace{0.45em}\color{ISISLine}\titlerule]
\titlespacing*{\chapter}{0pt}{-7pt}{28pt}
\titleformat{\section}{\Large\sffamily\bfseries\color{ISISDeepBlue}}{\textcolor{ThesisAccent}{\thesection}}{0.8em}{}
\titleformat{\subsection}{\large\sffamily\bfseries\color{ISISInk}}{\textcolor{ThesisAccent}{\thesubsection}}{0.8em}{}

