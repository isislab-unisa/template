% =============================================================================
% FAST DESIGN PRINCIPLES
% - pdfLaTeX only: compatible with Overleaf's default compiler.
% - no TikZ, PGFPlots, tcolorbox, minted, Biber, shell escape, or system fonts.
% - logos are pre-optimized PNG files; the watermark transparency is pre-baked.
% - visual components use native LaTeX rules, boxes, and the lightweight framed package.
% =============================================================================
\RequirePackage{iftex}
\ifPDFTeX\else
  \PackageError{isislab-thesis}{This project requires pdfLaTeX}{In Overleaf choose Menu -> Compiler -> pdfLaTeX.}
\fi
\RequirePackage[T1]{fontenc}
\RequirePackage[utf8]{inputenc}
\RequirePackage[english,italian]{babel}
\RequirePackage{lmodern}
\RequirePackage[scaled=0.92]{helvet}
\RequirePackage{geometry}
\geometry{a4paper,inner=30mm,outer=24mm,top=27mm,bottom=28mm,headheight=17pt,headsep=8mm,footskip=12mm}
\RequirePackage{xcolor}
\RequirePackage{graphicx}
\RequirePackage{eso-pic}
\RequirePackage{booktabs}
\RequirePackage{tabularx}
\RequirePackage{array}
\RequirePackage{framed}
\RequirePackage{scrlayer-scrpage}
\setlength{\footheight}{32pt}
\RequirePackage{zref-totpages}
\RequirePackage{etoolbox}
% ACM-Reference-Format.bst is designed for natbib-compatible citations.
% Numeric, sorted, compressed citations match the common ACM presentation.
\RequirePackage[numbers,sort&compress]{natbib}
\RequirePackage{hyperref}

