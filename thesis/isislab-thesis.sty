% Width of the complete progress bar
\newlength{\ISISProgressWidth}
\setlength{\ISISProgressWidth}{34mm}

% Pages not included in the progress calculation:
% 1 University cover + 1 ISISLab affiliation page
\newcommand{\ISISProgressOffset}{0}

\newcommand{\ISISProgressBar}{%
  \begingroup
  \dimen0=0pt

  % The total number of pages becomes available after the first compilation
  \ifnum\ztotpages>0\relax

    % Current physical PDF page, excluding the two title pages
    \count@=\numexpr
      \value{abspage}+1-\ISISProgressOffset
    \relax

    % Total PDF pages, excluding the two title pages
    \@tempcnta=\numexpr
      \ztotpages-\ISISProgressOffset
    \relax

    % Safety checks
    \ifnum\count@<1
      \count@=1
    \fi

    \ifnum\@tempcnta<1
      \@tempcnta=1
    \fi

    % Filled width = total width × current page / total pages
    \dimen0=\dimexpr
      \ISISProgressWidth*\count@/\@tempcnta
    \relax
  \fi

  % Prevent the filled bar from exceeding its maximum width
  \ifdim\dimen0>\ISISProgressWidth
    \dimen0=\ISISProgressWidth
  \fi

  % Remaining unfilled part
  \dimen2=\dimexpr
    \ISISProgressWidth-\dimen0
  \relax

  % Draw filled and unfilled sections
  \textcolor{ThesisAccent}{\rule{\dimen0}{1.1pt}}%
  \textcolor{ISISLine}{\rule{\dimen2}{1.1pt}}%
  \endgroup
}

\cfoot{%
  \ISISProgressBar
  \quad
  \sffamily\bfseries
  \textcolor{ISISDeepBlue}{\thepage}%
}


